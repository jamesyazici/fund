# Supabase — Settings → API
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>      # secret! server-only
SUPABASE_ANON_KEY=<anon-key>                       # used by seed script
SUPABASE_JWT_SECRET=<jwt-secret>                   # Settings → API → JWT Settings

# Alpaca (paper). Single-account fallback used when a pod has no stored creds —
# perfect for validating one pod end-to-end.
ALPACA_PAPER=true
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_API_KEY=<alpaca-paper-key>
ALPACA_API_SECRET=<alpaca-paper-secret>

# CORS: comma-separated origins, or * for dev
CORS_ORIGINS=*

# Admin portal Google Sign-In
# Create an OAuth Web client in Google Cloud and add your backend origin to
# Authorized JavaScript origins.
GOOGLE_OAUTH_CLIENT_ID=<google-oauth-web-client-id>.apps.googleusercontent.com
ADMIN_GOOGLE_EMAILS=<admin-google-email.com>
ADMIN_PORTAL_SECRET=<long-random-secret>
